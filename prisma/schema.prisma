generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SUPERVISOR
  SALES_ADVISOR
  CUSTOMER_SUPPORT
  MARKETING
}

enum LeadStatus {
  NEW
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
  POST_SALE
}

enum ChannelType {
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  TIKTOK
  EMAIL
  WEB
  INTERNAL
}

enum ConversationStatus {
  OPEN
  PENDING
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
  INTERNAL
}

enum MessageStatus {
  RECEIVED
  SENT
  DELIVERED
  SEEN
  FAILED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELED
}

enum TemplateCategory {
  WELCOME
  SALES
  MENU
  CATALOG
  PRICING
  PAYMENTS
  LOCATION
  FOLLOW_UP
  CLOSING
  POST_SALE
  REACTIVATION
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  FINISHED
  FAILED
}

enum DeliveryStatus {
  QUEUED
  SENT
  DELIVERED
  SEEN
  REPLIED
  FAILED
}

enum WorkflowTrigger {
  MESSAGE_RECEIVED
  SOCIAL_COMMENT
  STAGE_CHANGED
  LEAD_INACTIVE
  CAMPAIGN_EVENT
  TASK_OVERDUE
  MANUAL
}

enum WorkflowRunStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  CANCELED
}

enum AIDecisionAction {
  AUTO_REPLY
  LEAD_SCORE_UPDATE
  STAGE_MOVE
  TASK_CREATE
  HUMAN_HANDOFF
  CAMPAIGN_TRIGGER
  NONE
}

enum KnowledgeSourceType {
  FAQ
  TEMPLATE
  DOCUMENT
  CONVERSATION
  WEB
}

model User {
  id                String            @id @default(cuid())
  name              String?
  email             String            @unique
  emailVerified     DateTime?
  image             String?
  passwordHash      String?
  role              Role              @default(SALES_ADVISOR)
  locale            String            @default("es")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  accounts          Account[]
  sessions          Session[]
  leads             Lead[]            @relation("LeadAssignee")
  leadNotes         LeadNote[]        @relation("LeadNoteAuthor")
  conversations     Conversation[]    @relation("ConversationAssignee")
  sentMessages      Message[]         @relation("MessageSender")
  tasksAssigned     Task[]            @relation("TaskAssignee")
  tasksCreated      Task[]            @relation("TaskCreator")
  templatesCreated  Template[]        @relation("TemplateCreator")
  campaignsCreated  Campaign[]        @relation("CampaignCreator")
  workflowsCreated  Workflow[]        @relation("WorkflowCreator")
  aiReviewed        AIAgentDecision[] @relation("DecisionReviewer")
  knowledgeCreated  KnowledgeDocument[]
  branches          UserBranch[]
}

model UserBranch {
  id        String   @id @default(cuid())
  userId    String
  branchId  String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
}

model Branch {
  id              String           @id @default(cuid())
  name            String
  code            String           @unique
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  users           UserBranch[]
  leads           Lead[]
  conversations   Conversation[]
  tasks           Task[]
  campaigns       Campaign[]
  channelAccounts ChannelAccount[]
  purchases       Purchase[]
}

model PipelineStage {
  id         String    @id @default(cuid())
  name       String
  order      Int
  color      String    @default("#0ea5e9")
  isWon      Boolean   @default(false)
  isLost     Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  leads      Lead[]

  @@unique([name, order])
}

model Lead {
  id                    String            @id @default(cuid())
  firstName             String?
  lastName              String?
  fullName              String
  phone                 String?
  email                 String?
  socialHandle          String?
  company               String?
  city                  String?
  sourceChannel         ChannelType
  sourceDetail          String?
  status                LeadStatus        @default(NEW)
  stageId               String?
  assignedToId          String?
  branchId              String
  potentialValue        Decimal?          @db.Decimal(12, 2)
  tags                  String[]          @default([])
  notes                 String?
  lastMessageAt         DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  stage                 PipelineStage?    @relation(fields: [stageId], references: [id], onDelete: SetNull)
  assignedTo            User?             @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  branch                Branch            @relation(fields: [branchId], references: [id], onDelete: Restrict)
  conversations         Conversation[]
  messages              Message[]
  leadNotes             LeadNote[]
  tasks                 Task[]
  purchases             Purchase[]
  campaignDeliveries    CampaignDelivery[]
  workflowRuns          WorkflowRun[]
  aiDecisions           AIAgentDecision[]

  @@index([branchId, status])
  @@index([assignedToId])
  @@index([stageId])
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  authorId  String?
  content   String
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  author    User?    @relation("LeadNoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([leadId])
}

model Conversation {
  id               String             @id @default(cuid())
  leadId           String
  branchId         String
  channel          ChannelType
  externalThreadId String?
  status           ConversationStatus @default(OPEN)
  assignedToId     String?
  unreadCount      Int                @default(0)
  aiSummary        String?
  lastMessageAt    DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  lead             Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  branch           Branch             @relation(fields: [branchId], references: [id], onDelete: Restrict)
  assignedTo       User?              @relation("ConversationAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages         Message[]
  workflowRuns     WorkflowRun[]
  aiDecisions      AIAgentDecision[]

  @@index([leadId, channel])
  @@index([branchId, status])
}

model Message {
  id                String           @id @default(cuid())
  conversationId    String
  leadId            String
  direction         MessageDirection
  status            MessageStatus    @default(RECEIVED)
  content           String
  attachments       Json?
  externalMessageId String?
  metadata          Json?
  templateId        String?
  campaignId        String?
  workflowRunId     String?
  sentByUserId      String?
  sentAt            DateTime?
  createdAt         DateTime         @default(now())
  conversation      Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  lead              Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  template          Template?        @relation(fields: [templateId], references: [id], onDelete: SetNull)
  campaign          Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  workflowRun       WorkflowRun?     @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)
  sender            User?            @relation("MessageSender", fields: [sentByUserId], references: [id], onDelete: SetNull)
  aiDecisions       AIAgentDecision[]

  @@index([conversationId, createdAt])
  @@index([leadId, createdAt])
}

model Task {
  id            String       @id @default(cuid())
  leadId        String?
  branchId      String
  title         String
  description   String?
  dueAt         DateTime?
  priority      TaskPriority @default(MEDIUM)
  status        TaskStatus   @default(TODO)
  assignedToId  String?
  createdById   String?
  workflowRunId String?
  isAutomated   Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  lead          Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  branch        Branch       @relation(fields: [branchId], references: [id], onDelete: Restrict)
  assignedTo    User?        @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy     User?        @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  workflowRun   WorkflowRun? @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)

  @@index([assignedToId, status])
  @@index([branchId, dueAt])
}

model Template {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  category    TemplateCategory
  language    String           @default("es")
  content     String
  variables   String[]         @default([])
  isActive    Boolean          @default(true)
  createdById String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  createdBy   User?            @relation("TemplateCreator", fields: [createdById], references: [id], onDelete: SetNull)
  messages    Message[]
  campaigns   Campaign[]

  @@index([category, isActive])
}

model Campaign {
  id           String             @id @default(cuid())
  name         String
  channel      ChannelType        @default(WHATSAPP)
  status       CampaignStatus     @default(DRAFT)
  templateId   String?
  branchId     String
  createdById  String?
  segment      Json?
  metrics      Json?
  scheduledAt  DateTime?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  template     Template?          @relation(fields: [templateId], references: [id], onDelete: SetNull)
  branch       Branch             @relation(fields: [branchId], references: [id], onDelete: Restrict)
  createdBy    User?              @relation("CampaignCreator", fields: [createdById], references: [id], onDelete: SetNull)
  deliveries   CampaignDelivery[]
  messages     Message[]

  @@index([branchId, status])
}

model CampaignDelivery {
  id             String         @id @default(cuid())
  campaignId     String
  leadId         String
  status         DeliveryStatus @default(QUEUED)
  conversationId String?
  messageId      String?
  deliveredAt    DateTime?
  seenAt         DateTime?
  repliedAt      DateTime?
  errorMessage   String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  campaign       Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead           Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([campaignId, leadId])
  @@index([status])
}

model Workflow {
  id          String          @id @default(cuid())
  name        String
  description String?
  active      Boolean         @default(true)
  version     Int             @default(1)
  trigger     WorkflowTrigger
  definition  Json
  createdById String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  createdBy   User?           @relation("WorkflowCreator", fields: [createdById], references: [id], onDelete: SetNull)
  runs        WorkflowRun[]

  @@index([trigger, active])
}

model WorkflowRun {
  id             String            @id @default(cuid())
  workflowId     String
  leadId         String?
  conversationId String?
  status         WorkflowRunStatus @default(PENDING)
  triggerPayload Json?
  logs           Json?
  startedAt      DateTime?
  finishedAt     DateTime?
  error          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  workflow       Workflow          @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  lead           Lead?             @relation(fields: [leadId], references: [id], onDelete: SetNull)
  conversation   Conversation?     @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  tasks          Task[]
  messages       Message[]
  aiDecisions    AIAgentDecision[]

  @@index([workflowId, status])
}

model AIAgentDecision {
  id               String            @id @default(cuid())
  leadId           String?
  conversationId   String?
  messageId        String?
  workflowRunId    String?
  action           AIDecisionAction  @default(NONE)
  confidence       Float             @default(0)
  reasoning        String?
  requiresApproval Boolean           @default(false)
  citations        Json?
  metadata         Json?
  approvedById     String?
  approvedAt       DateTime?
  executedAt       DateTime?
  createdAt        DateTime          @default(now())
  lead             Lead?             @relation(fields: [leadId], references: [id], onDelete: SetNull)
  conversation     Conversation?     @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  message          Message?          @relation(fields: [messageId], references: [id], onDelete: SetNull)
  workflowRun      WorkflowRun?      @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)
  approvedBy       User?             @relation("DecisionReviewer", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
  @@index([requiresApproval])
}

model KnowledgeDocument {
  id          String              @id @default(cuid())
  title       String
  sourceType  KnowledgeSourceType
  sourceUrl   String?
  content     String
  chunkCount  Int                 @default(1)
  metadata    Json?
  isActive    Boolean             @default(true)
  createdById String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  createdBy   User?               @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([sourceType, isActive])
}

model ChannelAccount {
  id                String      @id @default(cuid())
  branchId          String
  channel           ChannelType
  displayName       String
  externalAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  metadata          Json?
  isActive          Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  branch            Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([channel, externalAccountId])
  @@index([branchId, channel, isActive])
}

model Purchase {
  id          String    @id @default(cuid())
  leadId      String
  branchId    String
  productName String
  quantity    Int       @default(1)
  unitPrice   Decimal   @db.Decimal(12, 2)
  total       Decimal   @db.Decimal(12, 2)
  purchasedAt DateTime  @default(now())
  notes       String?
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  branch      Branch    @relation(fields: [branchId], references: [id], onDelete: Restrict)

  @@index([leadId, purchasedAt])
}

model WebhookEvent {
  id         String   @id @default(cuid())
  provider   String
  eventType  String
  payload    Json
  processed  Boolean  @default(false)
  error      String?
  receivedAt DateTime @default(now())

  @@index([provider, eventType, receivedAt])
}

model WebAllowlistDomain {
  id         String   @id @default(cuid())
  domain     String   @unique
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

